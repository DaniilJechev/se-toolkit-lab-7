# Bot Environment Configuration
# Copy this file: cp .env.bot.example .env.bot.secret
# Then fill in the real values in .env.bot.secret

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your-telegram-bot-token-here

# LMS API Configuration
LMS_API_URL=http://localhost:42002
LMS_API_KEY=my-secret-api-key

# LLM API Configuration
LLM_API_KEY=my-secret-qwen-key
LLM_API_BASE_URL=http://localhost:42005/v1
LLM_API_MODEL=coder-model
